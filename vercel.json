{
  "cleanUrls": true,
  "functions": {
    "**/*.php": { "runtime": "vercel-php@0.7.2" }
  },
  "rewrites": [
    { "source": "/", "destination": "/html/index.html" },
    { "source": "/index", "destination": "/html/index.html" },
    { "source": "/modul", "destination": "/html/modul.html" },
    { "source": "/modullist", "destination": "/html/modullist.html" },
    { "source": "/isimodul", "destination": "/html/isimodul.html" },
    { "source": "/informasi", "destination": "/html/informasi.html" },
    { "source": "/tentang", "destination": "/html/tentang.html" },
    { "source": "/luaran", "destination": "/html/luaran.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/admin/index", "destination": "/admin/index.html" },
    { "source": "/admin/login", "destination": "/admin/login.html" },
    { "source": "/admin/modul", "destination": "/admin/modul.html" },
    { "source": "/admin/berita", "destination": "/admin/berita.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}